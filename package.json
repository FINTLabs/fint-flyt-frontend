{
    "name": "fint-flyt-frontend",
    "version": "0.1.0",
    "private": true,
    "proxy": "http://localhost:8080",
    "homepage": ".",
    "type": "module",
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "start": "vite",
        "preview": "vite preview",
        "serve": "node server.js",
        "build": "tsc && vite build",
        "test": "vitest",
        "cypress": "cypress run",
        "lint": "eslint --ext ts,tsx src",
        "forward": "sh ./startUpForwards.sh start",
        "stop-forward": "sh ./startUpForwards.sh stop"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^5.6.2",
        "@mui/material": "^5.7.0",
        "@navikt/aksel-icons": "^7.35.3",
        "@navikt/ds-css": "^7.35.3",
        "@navikt/ds-react": "^7.35.3",
        "date-fns": "^4.1.0",
        "express": "^5.2.1",
        "i18next": "^25.8.13",
        "lodash": "^4.17.23",
        "log4js": "^6.9.1",
        "morgan": "^1.10.1",
        "react": "^19.2.4",
        "react-dnd": "^16.0.1",
        "react-dnd-html5-backend": "^16.0.1",
        "react-dom": "^19.2.4",
        "react-hook-form": "7.71.2",
        "react-i18next": "^16.5.4",
        "react-router": "7.13.1"
    },
    "devDependencies": {
        "typescript": "^5.9.3",
        "@types/react-dom": "^19.2.3",
        "@types/react": "19.2.3",
        "@types/lodash": "^4.17.24",
        "@testing-library/jest-dom": "6.9.1",
        "@typescript-eslint/eslint-plugin": "^8.54.0",
        "@typescript-eslint/parser": "8.56.1",
        "@vitejs/plugin-react": "^5.1.1",
        "cypress": "15.11.0",
        "eslint": "10.0.2",
        "prettier": "^3.4.2",
        "vite": "^7.2.7",
        "vitest": "^4.0.15"
    },
    "jest": {
        "testMatch": [
            "**/?(*.)+(test).[jt]s?(x)"
        ]
    },
    "eslintConfig": {
        "extends": [
            "react-app",
            "react-app/jest"
        ]
    },
    "eslintIgnore": [
        "**.cy.js"
    ],
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    }
}
