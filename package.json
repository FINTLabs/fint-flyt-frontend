{
    "name": "fint-flyt-frontend",
    "version": "0.1.0",
    "private": true,
    "proxy": "http://localhost:8080",
    "homepage": ".",
    "type": "module",
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "start": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "serve": "node server.js",
        "test": "vitest",
        "cypress": "cypress run",
        "cy:open": "cypress open",
        "lint": "eslint src",
        "forward": "bash ./startUpForwards.sh start",
        "forward-stop": "bash ./startUpForwards.sh stop",
        "forward-stop-all": "bash ./startUpForwards.sh stop-all",
        "forward-status": "bash ./startUpForwards.sh status",
        "forward-check": "bash ./startUpForwards.sh check"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^5.6.2",
        "@mui/material": "^5.7.0",
        "@navikt/aksel-icons": "^7.35.3",
        "@navikt/ds-css": "^7.35.3",
        "@navikt/ds-react": "^7.35.3",
        "date-fns": "^4.1.0",
        "express": "^5.2.1",
        "helmet": "^8.1.0",
        "i18next": "^21.6.14",
        "log4js": "^6.9.1",
        "morgan": "^1.10.1",
        "react": "~18.3.1",
        "react-dnd": "^14.0.4",
        "react-dnd-html5-backend": "^14.0.2",
        "react-dom": "~18.3.1",
        "react-hook-form": "^7.72.1",
        "react-i18next": "^11.16.2",
        "react-router": "^7.18.1"
    },
    "devDependencies": {
        "@types/node": "^22.12.0",
        "@types/react": "18.3.27",
        "@types/react-dom": "^18.2.6",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "@vitejs/plugin-react": "^5.1.1",
        "cypress": "^15.18.0",
        "eslint": "^9.39.4",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "prettier": "^3.4.2",
        "typescript": "~5.4.0",
        "vite": "~7.3.6",
        "vitest": "^4.0.15"
    },
    "eslintIgnore": [
        "**.cy.js"
    ],
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    }
}
